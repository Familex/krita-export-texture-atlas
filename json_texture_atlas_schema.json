{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Krita Atlas Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "frames",
    "objects"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "image",
        "atlas_size"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "type": "string"
        },
        "atlas_size": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "w",
            "h"
          ],
          "properties": {
            "w": {
              "type": "integer",
              "minimum": 1
            },
            "h": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "frames": {
      "type": "object",
      "description": "Atlas rectangles indexed by frame name.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "w",
          "h"
        ],
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "w": {
            "type": "integer",
            "minimum": 1
          },
          "h": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/object"
      }
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "position",
        "children"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "frame": {
          "type": "string",
          "description": "Reference into the frames table."
        },
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          }
        },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          }
        },
        "z": {
          "type": "integer"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  }
}